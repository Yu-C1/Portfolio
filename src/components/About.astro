---
import { Image } from "astro:assets";
import Avatar_250 from "../Avatar_250.webp";
import { SectionTitle } from "./UI";
---

<section id="about" class="w-full min-h-screen px-6 py-4 pt-14 bg-background">
    <SectionTitle
        title="About Me"
        color="primary"
        className="h-screen flex flex-col justify-center"
    >
        <div class="flex_center flex-col lg:flex-row w-full h-full py-10 gap-8">
            <Image
                src={Avatar_250}
                alt="About_Avatar"
                class="Fade_Up rounded-full scale-x-[-1] lg:mx-14"
                width={225}
                height={225}
                loading="lazy"
            />

            <div
                class="Fade_Up w-full md:w-[80%] lg:w-[60%] flex justify-center items-start flex-col gap-4 lg:border-l border-primary py-8 lg:pl-10"
            >
                <h2 class="Fade_Up text-[1.5em] font-bold">Hey there! 👋</h2>
                <p class="Fade_Up text-justify">
                    I'm Yutao, a software engineer with a passion for building
                    tools that make developers' lives easier.
                </p>
                <p class="Fade_Up text-justify">
                    I love exploring new technologies and turning ideas into
                    real, useful software. From CLI tools to full-stack
                    applications, I enjoy working across the stack and diving
                    deep into problems worth solving.
                </p>
                <p class="Fade_Up text-justify">
                    If you're looking to collaborate or just want to chat about
                    tech, feel free to reach out!
                </p>
            </div>
        </div>
    </SectionTitle>
</section>

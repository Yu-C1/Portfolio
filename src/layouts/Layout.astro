---
import { SEO } from "astro-seo";
import { Header, MobileHeader, Cursor } from "../components/UI";
import { Footer } from "../components";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#1c1c1c" />
		<meta name="robots" content="index, follow" />
		<meta
			name="google-site-verification"
			content="YRAUUyc8TP4QJ1s53KAdLxcON9xifQf33BnLeP-F_5Y"
		/>
		<meta
			name="keywords"
			content="Yutao, Yutao Cai, software engineer, portfolio, structra, structra-cli, TypeScript, CLI tools, npm, developer tools, full stack"
		/>
		<meta name="author" content="Yutao Cai" />
		<meta name="publisher" content="Yutao Cai" />
		<link rel="manifest" href="/manifest.json" />

		<!-- Google Fonts: Inter + JetBrains Mono -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap"
		/>

		<!-- Preload CSS Styles -->
		<link rel="preload stylesheet" href="/styles/global.css" as="style" />
		<link rel="preload stylesheet" href="/styles/utility.css" as="style" />
		<link rel="preload stylesheet" href="/styles/cursor.css" as="style" />

		<SEO
			title="Yutao | Software Engineer Portfolio"
			description="Hi, I'm Yutao — a software engineer who loves exploring new tech and building interesting tools. Check out my projects including Structra, an AI-powered TypeScript CLI."
			canonical="https://yutaocai.vercel.app/"
			openGraph={{
				basic: {
					title: "Yutao | Software Engineer Portfolio",
					type: "website",
					image: "https://github.com/Yu-C1.png",
					url: "https://yutaocai.vercel.app/",
				},
			}}
			extend={{
				link: [
					{ rel: "icon", type: "image/png", href: "/favicon.png" },
					{
						rel: "shortcut",
						type: "image/png",
						href: "/favicon.png",
					},
					{
						rel: "apple-touch-icon",
						type: "image/png",
						href: "/favicon.png",
					},
				],
				meta: [
					{
						name: "twitter:url",
						content: "https://yutaocai.vercel.app/",
					},
				],
			}}
		/>


		<style is:global>
			:root {
				/* Base palette: dark charcoal */
				--base: #1c1c1c;
				--baseLite: rgba(28, 28, 28, 0.85);
				--text: #FFFFFF;
				--textImportant: #3BE2A2;
				--surface: #2a2a2a;
				--muted: #888888;

				/* Primary: mint green #3BE2A2 → HSL(157, 74%, 56%) */
				--pH: 157;
				--pS: 74%;
				--pL: 56%;

				/* Secondary: deeper mint → HSL(162, 65%, 42%) */
				--sH: 162;
				--sS: 65%;
				--sL: 42%;

				/* Mix: between primary and secondary */
				--mH: 159;
				--mS: 70%;
				--mL: 49%;

				--primary: var(--pH), var(--pS), var(--pL);
				--secondary: var(--sH), var(--sS), var(--sL);
				--mixColor: var(--mH), var(--mS), var(--mL);

				--primaryLite: hsla(var(--primary), 0.6);
				--primaryLiteAlt: hsla(var(--primary), 0.3);
				--secondaryLite: hsla(var(--secondary), 0.6);
				--secondaryLiteAlt: hsla(var(--secondary), 0.3);

				--footer: #141414;
				--footerSvgA: #111111;
				--footerSvgB: #0e0e0e;

				/* Text highlights: mint green */
				--gradient: linear-gradient(
					to right,
					#2BC48A,
					#3BE2A2,
					#3BE2A2,
					#2BC48A
				);
				--gradientLite: linear-gradient(
					45deg,
					rgba(59, 226, 162, 0.6),
					rgba(43, 196, 138, 0.6)
				);

				--headerGradient: linear-gradient(
					180deg,
					rgba(28, 28, 28, 0.8),
					transparent
				);
				--cardGradient: linear-gradient(
					45deg,
					#141414,
					var(--primaryLite)
				);
				--cardGradientAlt: linear-gradient(
					-135deg,
					#141414,
					var(--primaryLiteAlt)
				);
				--miscCardGradient: linear-gradient(
					-45deg,
					#141414,
					var(--primaryLiteAlt)
				);
				--overlayGradient: radial-gradient(
					farthest-corner at 100% 0%,
					hsla(157, 30%, 5%, 0.5),
					transparent
				);
				--LinkBtnGradient: linear-gradient(
					-135deg,
					rgba(20, 20, 20, 0.8),
					rgba(28, 28, 28, 0.6)
				);
				--SkillGradient: linear-gradient(
					-135deg,
					hsla(157, 40%, 8%, 0.8),
					hsla(162, 40%, 8%, 0.5)
				);
				--SkillGradientAlt: linear-gradient(
					-135deg,
					hsla(157, 40%, 8%, 0.4),
					hsla(162, 40%, 8%, 0.25)
				);
				--orbitGradient: conic-gradient(
					transparent,
					transparent,
					hsl(var(--primary)),
					hsl(var(--secondary)),
					#FFFFFF
				);
				--orbitGradientAlt: conic-gradient(
					#FFFFFF,
					hsl(var(--primary)),
					hsl(var(--secondary)),
					transparent,
					transparent
				);

				--orbitDotColor: #3BE2A2;
				--heroSocialColor: #FFFFFF;
				--contactSocialColor: hsla(157, 40%, 50%, 0.4);

				--cursorColor: hsla(157, 74%, 56%, 0.6);
				--cursorColorAlt: hsla(157, 74%, 56%, 0.8);
				--dotColor: #3BE2A2;
			}

			html.light {
				--base: #BBE1FA;
				--baseLite: rgba(187, 225, 250, 0.85);
				--text: #1B262C;
				--textImportant: #16A34A;
				--surface: #3282B8;
				--muted: #0F4C75;

				--pH: 204;
				--pS: 57%;
				--pL: 36%;

				--sH: 204;
				--sS: 77%;
				--sL: 20%;

				--mH: 204;
				--mS: 67%;
				--mL: 28%;

				--primary: var(--pH), var(--pS), var(--pL);
				--secondary: var(--sH), var(--sS), var(--sL);
				--mixColor: var(--mH), var(--mS), var(--mL);

				--primaryLite: hsla(var(--primary), 0.6);
				--primaryLiteAlt: hsla(var(--primary), 0.3);
				--secondaryLite: hsla(var(--secondary), 0.6);
				--secondaryLiteAlt: hsla(var(--secondary), 0.3);

				--footer: #A8D4F5;
				--footerSvgA: #C4E2F8;
				--footerSvgB: #D8EDFC;

				--gradient: linear-gradient(
					to right,
					#15803D,
					#22C55E,
					#22C55E,
					#15803D
				);
				--gradientLite: linear-gradient(
					45deg,
					rgba(34, 197, 94, 0.6),
					rgba(21, 128, 61, 0.6)
				);

				--headerGradient: linear-gradient(
					180deg,
					rgba(221, 230, 237, 0.8),
					transparent
				);
				--cardGradient: linear-gradient(
					45deg,
					hsla(var(--secondary), 0.1),
					var(--primaryLiteAlt)
				);
				--cardGradientAlt: linear-gradient(
					-135deg,
					var(--primaryLiteAlt),
					rgba(221, 230, 237, 1)
				);
				--miscCardGradient: linear-gradient(
					-45deg,
					var(--primaryLiteAlt),
					rgba(221, 230, 237, 1)
				);
				--overlayGradient: radial-gradient(
					farthest-corner at 100% 0%,
					hsla(207, 30%, 80%, 0.5),
					transparent
				);
				--LinkBtnGradient: linear-gradient(
					-135deg,
					hsla(var(--secondary), 0.15),
					hsla(var(--mixColor), 0.15)
				);
				--SkillGradient: linear-gradient(
					-135deg,
					hsla(var(--mixColor), 0.125),
					hsla(var(--primary), 0.25)
				);
				--SkillGradientAlt: linear-gradient(
					-135deg,
					hsla(var(--primary), 0.15),
					hsla(var(--secondary), 0.15)
				);
				--orbitGradient: conic-gradient(
					transparent,
					transparent,
					hsl(var(--secondary)),
					hsl(var(--primary))
				);
				--orbitGradientAlt: conic-gradient(
					hsl(var(--primary)),
					hsl(var(--secondary)),
					transparent,
					transparent
				);

				--orbitDotColor: hsl(var(--mixColor));
				--heroSocialColor: hsl(207, 40%, 20%);
				--contactSocialColor: hsla(204, 40%, 20%, 0.4);

				--cursorColor: hsla(var(--primary), 0.6);
				--cursorColorAlt: hsla(var(--primary), 0.6);
				--dotColor: hsl(var(--mixColor));
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html {
				font-family: 'JetBrains Mono', monospace !important;
			}

			code, pre {
				font-family: 'JetBrains Mono', monospace !important;
			}

			body {
				background-color: var(--base);
				color: var(--text);
			}

			/* Header */
			.Header_Nav a {
				position: relative;
				overflow: hidden;
				letter-spacing: 1px;
			}

			.Header_Nav a::after {
				content: "";
				position: absolute;
				bottom: 0;
				left: 0;
				width: 100%;
				height: 2px;
				background-color: var(--orbitDotColor);
				transform: scaleX(0);
				transition: transform 0.25s ease-out;
			}

			.Header_Nav a.active::after {
				transform: scaleX(1);
			}

			/* Action Button Style */
			.Header_ActionBtn {
				position: relative;
				border-radius: 0.2em;
				overflow: hidden;
				display: grid;
				place-items: center;
			}

			.Header_ActionBtn::after {
				content: "";
				position: absolute;
				width: 120%;
				aspect-ratio: 1;
				background: conic-gradient(
					hsl(var(--primary)),
					hsl(var(--secondary)),
					hsl(var(--primary))
				);
				animation: spin 5s linear infinite;
			}

			.Header_ActionBtn > div {
				padding: 0.2em 1.35em;
				background-color: var(--base);
				color: var(--text);
				border-radius: inherit;
				margin: 2px;
				z-index: 2;
			}

			/* Mobile Header Nav */
			.MobileHeader_Nav {
				min-width: 14em;
				text-align: center;
				background-color: var(--base);
				border-radius: 0.3em;
				padding: 1em;
				font-size: 1.3em;
				font-weight: 700;
				letter-spacing: 1px;
			}

			.MobileHeader_Nav a {
				width: 100%;
				color: var(--text);
				text-decoration: none;
				text-transform: uppercase;
			}

			.MobileHeader_Nav a.active {
				background: var(--gradient);
				background-clip: text;
				-webkit-background-clip: text;
				color: transparent;
				background-size: 200%;
				animation: gradientPan 5s linear infinite;
			}

			:has(.MobileHeader_ActionBtn).MobileHeader_Nav {
				padding: 0;
			}

			.MobileHeader_ActionBtn {
				position: relative;
				border-radius: 0.2em;
				overflow: hidden;
			}

			.MobileHeader_ActionBtn::after {
				content: "";
				position: absolute;
				width: 120%;
				aspect-ratio: 1;
				background: conic-gradient(
					hsl(var(--primary)),
					hsl(var(--secondary)),
					hsl(var(--primary))
				);
				animation: spin 5s linear infinite;
			}

			.MobileHeader_ActionBtn > div {
				padding: 0.7em 1em;
				width: 100%;
				background-color: var(--base);
				color: var(--text);
				border-radius: inherit;
				margin: 4px;
				z-index: 2;
			}

			/* Page Title Style */
			.Title-Tag {
				font-family: 'Inter', sans-serif;
			}

			.Title-Tag span,
			.Title-Tag p {
				z-index: 1;
				background-color: var(--base);
				padding-inline: 0.25em;
			}

			.Title-Tag.open {
				margin-bottom: 1em;
				justify-content: flex-start;
			}

			.Title-Tag.close {
				justify-content: flex-end;
				padding-top: 0.5em;
				opacity: 0.7 !important;
			}

			.Title-Tag.primary span {
				color: hsl(var(--primary));
			}

			.Title-Tag.secondary span {
				color: hsl(var(--secondary));
			}

			.Title_Line::after {
				content: "";
				position: absolute;
				margin-top: 0.3em;
				width: 100%;
				height: 2px;
				z-index: 0;
				background-color: var(--primaryLite);
			}

			.Title_Line.secondary::after {
				background-color: var(--secondaryLite);
			}

			.Title_Line.close::after {
				background-color: transparent;
			}

			/* Mobile Ham Menu Animation --> */
			.MobileNav_Ham {
				-webkit-tap-highlight-color: transparent;
				transition: transform 0.4s;
				user-select: none;
			}

			.MobileNav_Ham .line {
				fill: none;
				transition:
					stroke-dasharray 0.4s,
					stroke-dashoffset 0.4s;
				stroke: var(--text);
				stroke-width: 5.5;
				transform-origin: right;
				stroke-linecap: round;
			}

			html.light .MobileNav_Ham .line {
				stroke: hsl(var(--primary)) !important;
			}

			.MobileNav_Ham .top {
				stroke-dasharray: 18 160;
			}

			.MobileNav_Ham .middle {
				stroke-dasharray: 40 142;
				transform-origin: 83% 83%;
				transition: transform 0.4s;
			}

			.MobileNav_Ham .bottom {
				stroke-dasharray: 18 85;
				transform-origin: 50%;
				transition:
					transform 0.4s,
					stroke-dashoffset 0.4s;
			}

			.Projects_Link {
				padding: 0.45em;
				border: 1px solid var(--primaryLite);
				border-radius: 100%;
				z-index: 10;
			}

			/* Cursor */
			.Cursor-Main {
				position: absolute;
				width: 100%;
				height: 100%;
				inset: 0;
				z-index: 9999;
				overflow: hidden;
				pointer-events: none;
			}

			/* Hero */
			.Hero_Trail {
				position: absolute;
				aspect-ratio: 1;
				border-radius: 50%;
				animation: spin 6s linear infinite;
				animation-delay: 1s;
			}

			.Hero_Trail::before {
				content: "";
				width: calc(100% - 1%);
				aspect-ratio: 1;
				inset: 0;
				margin: auto;
				border-radius: 50%;
				position: absolute;
				background-color: var(--base);
			}

			.Trail1 {
				width: 60%;
				background: var(--orbitGradient);
				z-index: 5;
			}

			.Trail2 {
				width: 70%;
				animation-duration: 8s;
				animation-direction: reverse;
				background: var(--orbitGradientAlt);
				z-index: 4;
			}

			.Trail3 {
				width: 80%;
				background: var(--orbitGradient);
				animation-duration: 10s;
				z-index: 3;
			}

			.Trail4 {
				width: 90%;
				animation-duration: 12s;
				animation-direction: reverse;
				background: var(--orbitGradientAlt);
				z-index: 2;
			}

			.Trail2 span,
			.Trail4 span {
				transform: rotate(140deg) !important;
			}

			footer {
				color: #fff !important;
			}

			/* Lenis Smooth Scroll */
			html.lenis {
				height: auto;
			}

			.lenis.lenis-smooth {
				scroll-behavior: auto !important;
			}

			.lenis.lenis-smooth [data-lenis-prevent] {
				overscroll-behavior: contain;
			}

			.lenis.lenis-stopped {
				overflow: hidden;
			}

			.lenis.lenis-scrolling iframe {
				pointer-events: none;
			}

			/* GSAP Animation inits */
			.flex_center {
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.gradientText {
				background: var(--gradient);
				background-clip: text;
				-webkit-background-clip: text;
				color: transparent;
				background-size: 200%;
				animation: gradientPan 5s linear infinite;
				will-change: background-position;
			}

			.Orbit_Dot {
				width: 0.5em;
				aspect-ratio: 1;
				background-color: var(--orbitDotColor);
				border-radius: 0 50% 50%;
				transform: rotate(-45deg);
				position: absolute;
				top: -0.2em;
				left: 49%;
				transition: 0.25s ease-in-out;
				overflow: hidden;
				box-shadow: 0 0 10px var(--orbitDotColor);
			}

			:has(.Hero_Orbit:hover) .Orbit_Dot {
				background-color: var(--base) !important;
				outline: 0.5px solid var(--orbitDotColor);
				/* border-radius: 50% !important; */
				scale: 1.8;
			}

			.Fade_Stagger,
			.Fade_Up {
				opacity: 0;
				transform: translateY(50);
			}

			.Fade_Down {
				opacity: 0;
				transform: translateY(-50);
			}

			.Fade_In {
				opacity: 0;
			}

			.Spring_Up {
				opacity: 0;
				scale: 0.75;
			}

			@keyframes spin {
				0% {
					rotate: 0deg;
				}

				100% {
					rotate: 360deg;
				}
			}
		</style>
	</head>
	<body id="home">
		<Header />
		<MobileHeader />

		<main>
			<slot />
		</main>

		<Footer />
		<Cursor />
		<script src="../script.ts"></script>
	</body>
</html>
